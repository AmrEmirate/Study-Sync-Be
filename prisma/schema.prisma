generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int      @id @default(autoincrement())
  google_id             String?  @unique
  nama_lengkap          String
  email                 String   @unique
  password              String?  // Nullable for social login users
  otp                   String?  // For email verification
  is_verified           Boolean  @default(false)
  profile_picture       String?  // Base64 or URL
  identitas             String?  // JSON string or plain text for identity
  preferensi_notifikasi Boolean  @default(true)
  tasks                 Task[]
  integrations          SchoolIntegration[]
}

model Task {
  id             Int      @id @default(autoincrement())
  user_id        Int
  judul_tugas    String
  deskripsi      String?
  batas_waktu    DateTime?
  status         String   @default("BELUM_SELESAI") // "BELUM_SELESAI", "PROSES", "SELESAI"
  sumber         String   @default("manual") // "manual" or "sekolah"
  user           User     @relation(fields: [user_id], references: [id])
}

model SchoolIntegration {
  id                       Int      @id @default(autoincrement())
  user_id                  Int
  endpoint_url             String
  auth_token               String
  waktu_sinkronisasi_terakhir DateTime?
  user                     User     @relation(fields: [user_id], references: [id])
}
